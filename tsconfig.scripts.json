{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2017",
    "noEmit": false,
    "outDir": "./.ts-scripts-out",
    "esModuleInterop": true,
    "downlevelIteration": true
  },
  "include": ["scripts/**/*.ts", "lib/types.ts"]
}
